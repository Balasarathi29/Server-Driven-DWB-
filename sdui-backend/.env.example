# Core backend settings
PORT=5001
NODE_ENV=development
MONGODB_URI=
REDIS_URL=
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ALLOWED_ORIGINS=http://localhost:3000

# ------------------------------------------------------------
# IMAGE GENERATION PROVIDERS (free local + paid OpenAI)
# ------------------------------------------------------------
# AI_IMAGE_PROVIDER values: auto | local | openai
# - auto: use OpenAI if key exists, otherwise local endpoint if configured
# - local: force local image endpoint (free)
# - openai: force OpenAI image API (paid)
AI_IMAGE_PROVIDER=auto

# Local free image API endpoint (example: AUTOMATIC1111 txt2img)
# Example: http://127.0.0.1:7860/sdapi/v1/txt2img
LOCAL_IMAGE_API_URL=
LOCAL_IMAGE_MODEL=local-stable-diffusion

# Keep false for prompt-accurate-only behavior.
# Set true only if you want generic placeholder images when providers fail.
AI_IMAGE_ALLOW_FALLBACK=false

# ------------------------------------------------------------
# EMAIL CONFIGURATION (Choose ONE provider: Resend OR SMTP)
# ------------------------------------------------------------

# Option 1: RESEND (recommended)
# 1) Create API key in Resend dashboard
# 2) Verify your sending domain / sender email in Resend
# 3) Paste values below
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=no-reply@yourdomain.com

# Optional typo-compatible aliases also supported by app code
RESENT_API_KEY=
RESENT_FROM_EMAIL=

# Option 2: SMTP (example: Gmail App Password)
# For Gmail:
# SMTP_SERVICE=gmail
# SMTP_USER=yourgmail@gmail.com
# SMTP_PASS=your_16_char_app_password
# SMTP_FROM_EMAIL=yourgmail@gmail.com
#
# Generic SMTP example:
# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587
# SMTP_USER=your_user
# SMTP_PASS=your_password
# SMTP_FROM_EMAIL=no-reply@yourdomain.com
SMTP_SERVICE= gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER= 
SMTP_PASS=
SMTP_FROM_EMAIL=

# Common SMTP aliases also supported by app code
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_SERVICE=
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=

# ------------------------------------------------------------
# QUICK START
# ------------------------------------------------------------
# 1) Copy this file to .env
# 2) Fill either Resend or SMTP values
# 3) Restart backend: npm run dev
# 4) Click "Test Recipient Email" in form settings
